<!DOCTYPE html>
<html>
<head>
<title>Ping Pong World Tour</title>
<style>

body{
background:#0f172a;
color:white;
font-family:Arial;
text-align:center;
}

canvas{
background:linear-gradient(#1e293b,#020617);
border:3px solid white;
display:block;
margin:auto;
}

button{
padding:10px;
margin:5px;
font-size:16px;
cursor:pointer;
}

.shop{
margin-top:10px;
}

</style>
</head>

<body>

<h1>🏓 Ping Pong World Tour 🌍</h1>

<div>
Coins: <span id="coins">0</span>
</div>

<div id="menu">

<h3>🌎 Tournament</h3>

<button onclick="startMatch('Japan',3)">🇯🇵 Japan</button>
<button onclick="startMatch('Germany',4)">🇩🇪 Germany</button>
<button onclick="startMatch('UK',4)">🇬🇧 UK</button>
<button onclick="startMatch('USA',5)">🇺🇸 USA</button>
<button onclick="startMatch('China',6)">🇨🇳 China</button>

</div>

<div class="shop">

<h3>🛍 Racket Shop</h3>

<button onclick="buyRacket('speed',50)">Speed (50)</button>
<button onclick="buyRacket('giant',40)">Giant (40)</button>
<button onclick="buyRacket('power',100)">Power (100)</button>

</div>

<h2 id="score">0 : 0</h2>

<canvas id="game" width="900" height="500"></canvas>

<script>

const canvas = document.getElementById("game")
const ctx = canvas.getContext("2d")

let coins = Number(localStorage.getItem("coins")) || 0
let rackets = JSON.parse(localStorage.getItem("rackets")) || ["normal"]
let equipped = localStorage.getItem("equipped") || "normal"

document.getElementById("coins").innerText = coins

function save(){
localStorage.setItem("coins",coins)
localStorage.setItem("rackets",JSON.stringify(rackets))
localStorage.setItem("equipped",equipped)
}

let player={
x:40,
y:200,
w:18,
h:100,
score:0
}

let ai={
x:840,
y:200,
w:18,
h:100,
score:0,
speed:3
}

let ball={
x:450,
y:250,
vx:5,
vy:3,
r:10,
z:0
}

let powerReady=true

function startMatch(country,difficulty){

player.score=0
ai.score=0
ai.speed=difficulty

alert("Playing against "+country)

}

function buyRacket(type,cost){

if(rackets.includes(type)){
equipped=type
alert("Equipped "+type)
save()
return
}

if(coins>=cost){

coins-=cost
rackets.push(type)
equipped=type

document.getElementById("coins").innerText=coins

alert("Purchased "+type+" racket!")

save()

}else{

alert("Not enough coins!")

}

}

canvas.addEventListener("mousemove",e=>{
let rect=canvas.getBoundingClientRect()
player.y=e.clientY-rect.top-player.h/2
})

canvas.addEventListener("touchmove",e=>{

let rect=canvas.getBoundingClientRect()
player.y=e.touches[0].clientY-rect.top-player.h/2

})

document.addEventListener("keydown",e=>{

if(e.code==="Space" && powerReady){

ball.vx*=1.8
powerReady=false

setTimeout(()=>{
powerReady=true
},2000)

}

})

function resetBall(){

ball.x=canvas.width/2
ball.y=canvas.height/2
ball.vx*=-1

}

function update(){

ball.x+=ball.vx
ball.y+=ball.vy

if(ball.y<0 || ball.y>canvas.height){
ball.vy*=-1
}

if(ball.x<player.x+player.w &&
ball.y>player.y &&
ball.y<player.y+player.h){

ball.vx=Math.abs(ball.vx)

}

if(ball.x>ai.x &&
ball.y>ai.y &&
ball.y<ai.y+ai.h){

ball.vx=-Math.abs(ball.vx)

}

if(ball.x<0){

ai.score++
resetBall()

}

if(ball.x>canvas.width){

player.score++
coins+=10
document.getElementById("coins").innerText=coins
save()
resetBall()

}

ai.y+=((ball.y-(ai.y+ai.h/2))*0.08)*ai.speed

document.getElementById("score").innerText=
player.score+" : "+ai.score

}

function drawTable(){

let grad=ctx.createLinearGradient(0,0,0,500)
grad.addColorStop(0,"#1e293b")
grad.addColorStop(1,"#020617")

ctx.fillStyle=grad
ctx.fillRect(0,0,canvas.width,canvas.height)

ctx.strokeStyle="white"
ctx.setLineDash([10,10])
ctx.beginPath()
ctx.moveTo(canvas.width/2,0)
ctx.lineTo(canvas.width/2,canvas.height)
ctx.stroke()

ctx.setLineDash([])

}

function draw(){

drawTable()

ctx.fillStyle="white"
ctx.fillRect(player.x,player.y,player.w,player.h)

ctx.fillRect(ai.x,ai.y,ai.w,ai.h)

let size=ball.r + ball.z

ctx.beginPath()
ctx.arc(ball.x,ball.y,size,0,Math.PI*2)
ctx.fill()

}

function game(){

update()
draw()

requestAnimationFrame(game)

}

game()

</script>

</body>
</html>
